# ═══════════════════════════════════════════════
# Sharky Strategy Bot — Configuration
# ═══════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Wallet & Authentication ──
# Your Polygon wallet private key (without 0x prefix)
# This is the key that signs orders on the CLOB
POLYMARKET_PRIVATE_KEY=

# Your wallet address that holds USDC (the funder)
# For EOA wallets, this is your main wallet address
POLYMARKET_FUNDER_ADDRESS=

# Signature type:
#   0 = Standard EOA (MetaMask, hardware wallet, generated key)
#   1 = Magic/Email wallet
#   2 = Browser proxy wallet
POLYMARKET_SIGNATURE_TYPE=0

# ── Strategy Parameters ──
# Amount in USD to trade per market
TRADE_AMOUNT_USD=10.0

# Seconds before market close to place the trade
SECONDS_BEFORE_CLOSE=2

# Comma-separated list of crypto assets to trade
ASSETS=BTC,ETH,XRP,SOL

# ── Operational ──
# How often (in seconds) to scan for new markets
SCAN_INTERVAL=30

# Set to "false" for LIVE trading (real money!)
# Keep as "true" to test without placing real orders
DRY_RUN=true

# Log file paths
LOG_FILE=sharky_bot.log
TRADE_LOG_FILE=trades.json
